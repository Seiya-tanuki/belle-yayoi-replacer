# --- OS / Editor ---
.DS_Store
Thumbs.db

# --- Python ---
__pycache__/
*.pyc
*.pyo

# --- Virtualenv ---
.venv/
venv/

# --- Temp / Scratch ---
tmp/
.tmp*/
*.tmp

# --- Field assets (runtime-managed, do not version) ---
clients/**
!clients/TEMPLATE/
!clients/TEMPLATE/**
exports/**

# --- Lexicon pending (runtime-managed, not versioned) ---
lexicon/*/pending/**

# Keep placeholders
!lexicon/*/pending/.gitkeep
!lexicon/*/pending/locks/
!lexicon/*/pending/locks/.gitkeep
